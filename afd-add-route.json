{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.41.2.15936",
      "templateHash": "7466276309189619420"
    }
  },
  "parameters": {
    "frontDoorProfileName": {
      "type": "string",
      "minLength": 1,
      "metadata": {
        "description": "Name of the existing Azure Front Door Standard/Premium profile."
      }
    },
    "afdEndpointName": {
      "type": "string",
      "minLength": 1,
      "metadata": {
        "description": "Name of the existing AFD endpoint within the profile to attach the route to."
      }
    },
    "appServiceHostname": {
      "type": "string",
      "minLength": 1,
      "metadata": {
        "description": "Hostname of the App Service origin (e.g. myapp.azurewebsites.net)."
      }
    },
    "originGroupName": {
      "type": "string",
      "defaultValue": "pseudoai-origins",
      "metadata": {
        "description": "Name for the new AFD origin group."
      }
    },
    "originName": {
      "type": "string",
      "defaultValue": "pseudoai-appservice",
      "metadata": {
        "description": "Name for the new AFD origin within the group."
      }
    },
    "routeName": {
      "type": "string",
      "defaultValue": "pseudoai-route",
      "metadata": {
        "description": "Name for the new AFD route on the endpoint."
      }
    },
    "routePatterns": {
      "type": "array",
      "defaultValue": [
        "/*"
      ],
      "metadata": {
        "description": "URL path patterns that this route matches."
      }
    },
    "routeProtocols": {
      "type": "string",
      "defaultValue": "HttpsOnly",
      "allowedValues": [
        "HttpsOnly",
        "HttpOnly",
        "HttpAndHttps"
      ],
      "metadata": {
        "description": "Accepted protocols for this route."
      }
    },
    "httpsRedirect": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "When true, HTTP requests are redirected to HTTPS."
      }
    },
    "healthProbeIntervalSeconds": {
      "type": "int",
      "defaultValue": 30,
      "minValue": 5,
      "maxValue": 255,
      "metadata": {
        "description": "Health-probe interval in seconds (5–255)."
      }
    },
    "addCustomDomain": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "When true, also registers a custom domain in Front Door and provisions a managed TLS certificate."
      }
    },
    "customSubdomain": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Subdomain label for the custom domain (e.g. pseudoai). Required when addCustomDomain is true."
      }
    },
    "customDomainZone": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Apex DNS zone for the custom domain (e.g. customer.com). Required when addCustomDomain is true."
      }
    }
  },
  "variables": {
    "supportedProtocols": "[if(equals(parameters('routeProtocols'), 'HttpsOnly'), createArray('Https'), if(equals(parameters('routeProtocols'), 'HttpOnly'), createArray('Http'), createArray('Http', 'Https')))]",
    "customDomainResourceName": "[if(parameters('addCustomDomain'), format('{0}-{1}', parameters('customSubdomain'), replace(parameters('customDomainZone'), '.', '-')), 'placeholder')]"
  },
  "resources": [
    {
      "type": "Microsoft.Cdn/profiles/originGroups",
      "apiVersion": "2024-02-01",
      "name": "[format('{0}/{1}', parameters('frontDoorProfileName'), parameters('originGroupName'))]",
      "properties": {
        "loadBalancingSettings": {
          "sampleSize": 4,
          "successfulSamplesRequired": 3,
          "additionalLatencyInMilliseconds": 50
        },
        "healthProbeSettings": {
          "probePath": "/",
          "probeRequestType": "HEAD",
          "probeProtocol": "Https",
          "probeIntervalInSeconds": "[parameters('healthProbeIntervalSeconds')]"
        },
        "sessionAffinityState": "Disabled"
      }
    },
    {
      "type": "Microsoft.Cdn/profiles/originGroups/origins",
      "apiVersion": "2024-02-01",
      "name": "[format('{0}/{1}/{2}', parameters('frontDoorProfileName'), parameters('originGroupName'), parameters('originName'))]",
      "properties": {
        "hostName": "[parameters('appServiceHostname')]",
        "httpPort": 80,
        "httpsPort": 443,
        "originHostHeader": "[parameters('appServiceHostname')]",
        "priority": 1,
        "weight": 1000,
        "enabledState": "Enabled"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Cdn/profiles/originGroups', parameters('frontDoorProfileName'), parameters('originGroupName'))]"
      ]
    },
    {
      "condition": "[parameters('addCustomDomain')]",
      "type": "Microsoft.Cdn/profiles/customDomains",
      "apiVersion": "2024-02-01",
      "name": "[format('{0}/{1}', parameters('frontDoorProfileName'), variables('customDomainResourceName'))]",
      "properties": {
        "hostName": "[format('{0}.{1}', parameters('customSubdomain'), parameters('customDomainZone'))]",
        "tlsSettings": {
          "certificateType": "ManagedCertificate",
          "minimumTlsVersion": "TLS12"
        }
      }
    },
    {
      "type": "Microsoft.Cdn/profiles/afdEndpoints/routes",
      "apiVersion": "2024-02-01",
      "name": "[format('{0}/{1}/{2}', parameters('frontDoorProfileName'), parameters('afdEndpointName'), parameters('routeName'))]",
      "properties": {
        "originGroup": {
          "id": "[resourceId('Microsoft.Cdn/profiles/originGroups', parameters('frontDoorProfileName'), parameters('originGroupName'))]"
        },
        "supportedProtocols": "[variables('supportedProtocols')]",
        "patternsToMatch": "[parameters('routePatterns')]",
        "forwardingProtocol": "HttpsOnly",
        "linkToDefaultDomain": "Enabled",
        "httpsRedirect": "[if(parameters('httpsRedirect'), 'Enabled', 'Disabled')]",
        "enabledState": "Enabled",
        "customDomains": "[if(parameters('addCustomDomain'), createArray(createObject('id', resourceId('Microsoft.Cdn/profiles/customDomains', parameters('frontDoorProfileName'), variables('customDomainResourceName')))), createArray())]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Cdn/profiles/customDomains', parameters('frontDoorProfileName'), variables('customDomainResourceName'))]",
        "[resourceId('Microsoft.Cdn/profiles/originGroups/origins', parameters('frontDoorProfileName'), parameters('originGroupName'), parameters('originName'))]",
        "[resourceId('Microsoft.Cdn/profiles/originGroups', parameters('frontDoorProfileName'), parameters('originGroupName'))]"
      ]
    }
  ]
}
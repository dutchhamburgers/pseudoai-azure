{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.41.2.15936",
      "templateHash": "10058217869091246799"
    }
  },
  "parameters": {
    "appName": {
      "type": "string",
      "metadata": {
        "description": "Base name for all resources (e.g. pseudoai-prod). Must be globally unique for the Web App."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for all resources. Defaults to the resource group location."
      }
    },
    "sku": {
      "type": "string",
      "defaultValue": "B1",
      "allowedValues": [
        "B1",
        "B2",
        "B3",
        "S1",
        "S2",
        "S3",
        "P1v3",
        "P2v3",
        "P3v3"
      ],
      "metadata": {
        "description": "App Service Plan pricing tier. B1 is the smallest Linux tier that supports containers."
      }
    },
    "imageTag": {
      "type": "string",
      "defaultValue": "latest",
      "metadata": {
        "description": "Container image tag to deploy. Use \"latest\" or a specific \"sha-<shortsha>\" tag."
      }
    },
    "enableAppInsights": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Deploy Application Insights and Log Analytics workspace for monitoring."
      }
    },
    "sumupApiKey": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": {
        "description": "SumUp secret API key (server-side only). Leave empty to configure later."
      }
    },
    "sumupMerchantCode": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "SumUp merchant code. Leave empty to configure later."
      }
    },
    "initialUserPassword": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": {
        "description": "Initial admin password for PseudoAI. Change after first login."
      }
    },
    "openaiApiKey": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": {
        "description": "OpenAI API key for AI integration (optional). Leave empty to disable."
      }
    }
  },
  "variables": {
    "planName": "[format('{0}-plan', parameters('appName'))]",
    "insightsName": "[format('{0}-insights', parameters('appName'))]",
    "workspaceName": "[format('{0}-logs', parameters('appName'))]",
    "imageBase": "ghcr.io/dutchhamburgers/pseudoai-azure"
  },
  "resources": [
    {
      "condition": "[parameters('enableAppInsights')]",
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2022-10-01",
      "name": "[variables('workspaceName')]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": {
          "name": "PerGB2018"
        },
        "retentionInDays": 30
      }
    },
    {
      "condition": "[parameters('enableAppInsights')]",
      "type": "Microsoft.Insights/components",
      "apiVersion": "2020-02-02",
      "name": "[variables('insightsName')]",
      "location": "[parameters('location')]",
      "kind": "web",
      "properties": {
        "Application_Type": "web",
        "WorkspaceResourceId": "[if(parameters('enableAppInsights'), resourceId('Microsoft.OperationalInsights/workspaces', variables('workspaceName')), null())]",
        "publicNetworkAccessForIngestion": "Enabled",
        "publicNetworkAccessForQuery": "Enabled"
      },
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', variables('workspaceName'))]"
      ]
    },
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2023-01-01",
      "name": "[variables('planName')]",
      "location": "[parameters('location')]",
      "kind": "linux",
      "sku": {
        "name": "[parameters('sku')]"
      },
      "properties": {
        "reserved": true
      }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2024-04-01",
      "name": "[parameters('appName')]",
      "location": "[parameters('location')]",
      "kind": "app,linux,container",
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('planName'))]",
        "httpsOnly": true,
        "siteConfig": {
          "linuxFxVersion": "[format('DOCKER|{0}/web:{1}', variables('imageBase'), parameters('imageTag'))]",
          "appSettings": "[flatten(createArray(createArray(createObject('name', 'WEBSITES_PORT', 'value', '80'), createObject('name', 'WEBSITES_ENABLE_APP_SERVICE_STORAGE', 'value', 'false'), createObject('name', 'WEBSITE_CONTAINER_START_TIME_LIMIT', 'value', '600'), createObject('name', 'IMAGE_TAG', 'value', parameters('imageTag')), createObject('name', 'API_UPSTREAM', 'value', 'localhost:8081'), createObject('name', 'NLP_UPSTREAM', 'value', 'localhost:5000')), if(parameters('enableAppInsights'), createArray(createObject('name', 'APPLICATIONINSIGHTS_CONNECTION_STRING', 'value', coalesce(tryGet(if(parameters('enableAppInsights'), reference(resourceId('Microsoft.Insights/components', variables('insightsName')), '2020-02-02', 'full'), null()), 'properties', 'ConnectionString'), ''))), createArray())))]"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Insights/components', variables('insightsName'))]",
        "[resourceId('Microsoft.Web/serverfarms', variables('planName'))]"
      ]
    },
    {
      "type": "Microsoft.Web/sites/sitecontainers",
      "apiVersion": "2024-04-01",
      "name": "[format('{0}/{1}', parameters('appName'), 'api-php')]",
      "properties": {
        "image": "[format('{0}/api-php:{1}', variables('imageBase'), parameters('imageTag'))]",
        "isMain": false,
        "targetPort": "8081",
        "authType": "Anonymous",
        "environmentVariables": [
          {
            "name": "APP_MODE",
            "value": "single"
          },
          {
            "name": "SUMUP_API_KEY",
            "value": "[parameters('sumupApiKey')]"
          },
          {
            "name": "SUMUP_MERCHANT_CODE",
            "value": "[parameters('sumupMerchantCode')]"
          },
          {
            "name": "SUMUP_API_BASE_URL",
            "value": "https://api.sumup.com/v0.1"
          },
          {
            "name": "FRONTEND_BASE_URL",
            "value": "[format('https://{0}.azurewebsites.net', parameters('appName'))]"
          },
          {
            "name": "CORS_ALLOWED_ORIGINS",
            "value": "[format('https://{0}.azurewebsites.net', parameters('appName'))]"
          },
          {
            "name": "NLP_PYTHON_ENABLED",
            "value": "true"
          },
          {
            "name": "NLP_PYTHON_URL",
            "value": "http://localhost:5000"
          },
          {
            "name": "NLP_PYTHON_DEADLINE_SECONDS",
            "value": "35"
          },
          {
            "name": "NLP_PYTHON_NER_ENABLED",
            "value": "false"
          },
          {
            "name": "NLP_PII_HINTS_ENABLED",
            "value": "false"
          },
          {
            "name": "MASK_SINGLE_NAMES_DEFAULT",
            "value": "false"
          },
          {
            "name": "AUTO_CREATE_INITIAL_USER",
            "value": "true"
          },
          {
            "name": "INITIAL_USER_USERNAME",
            "value": "user"
          },
          {
            "name": "INITIAL_USER_PASSWORD",
            "value": "[parameters('initialUserPassword')]"
          },
          {
            "name": "INITIAL_USER_EMAIL",
            "value": ""
          },
          {
            "name": "OPENAI_API_KEY",
            "value": "[parameters('openaiApiKey')]"
          },
          {
            "name": "AI_MODEL_DEFAULT",
            "value": "gpt-4o-mini"
          },
          {
            "name": "AI_MAX_OUTPUT_TOKENS_CAP",
            "value": "2048"
          },
          {
            "name": "AI_MAX_INPUT_CHARS_CAP",
            "value": "40000"
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', parameters('appName'))]"
      ]
    },
    {
      "type": "Microsoft.Web/sites/sitecontainers",
      "apiVersion": "2024-04-01",
      "name": "[format('{0}/{1}', parameters('appName'), 'nlp-python')]",
      "properties": {
        "image": "[format('{0}/nlp-python:{1}', variables('imageBase'), parameters('imageTag'))]",
        "isMain": false,
        "targetPort": "5000",
        "authType": "Anonymous",
        "environmentVariables": [
          {
            "name": "FLASK_DEBUG",
            "value": "false"
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', parameters('appName'))]"
      ]
    }
  ],
  "outputs": {
    "appUrl": {
      "type": "string",
      "metadata": {
        "description": "The public URL of the deployed PseudoAI application."
      },
      "value": "[format('https://{0}', reference(resourceId('Microsoft.Web/sites', parameters('appName')), '2024-04-01').defaultHostName)]"
    },
    "webAppId": {
      "type": "string",
      "metadata": {
        "description": "Resource ID of the Web App."
      },
      "value": "[resourceId('Microsoft.Web/sites', parameters('appName'))]"
    }
  }
}
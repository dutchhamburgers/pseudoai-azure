        "authType": "[if(variables('useGhcrCredentials'), 'UserCredentials', 'Anonymous')]",
        "userName": "[if(variables('useGhcrCredentials'), variables('ghcrUsername'), null())]",
        "passwordSecret": "[if(variables('useGhcrCredentials'), variables('ghcrToken'), null())]",
        "environmentVariables": [
          {
            "name": "FLASK_DEBUG",
            "value": "false"
          },
          {
            "name": "BAG_DATA_DIR",
            "value": "/data"
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', parameters('appName'))]"
      ]
    }
  ],
  "outputs": {
    "appUrl": {
      "type": "string",
      "metadata": {
        "description": "The public URL of the deployed PseudoAI application."
      },
      "value": "[format('https://{0}', reference(resourceId('Microsoft.Web/sites', parameters('appName')), '2024-04-01').defaultHostName)]"
    },
    "webAppId": {
      "type": "string",
      "metadata": {
        "description": "Resource ID of the Web App."
      },
      "value": "[resourceId('Microsoft.Web/sites', parameters('appName'))]"
    },
    "keyVaultName": {
      "type": "string",
      "metadata": {
        "description": "Name of the Key Vault that stores application secrets."
      },
      "value": "[variables('keyVaultName')]"
    },
    "keyVaultUri": {
      "type": "string",
      "metadata": {
        "description": "URI of the Key Vault."
      },
      "value": "[reference(resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName')), '2023-07-01').vaultUri]"
    },
    "storageAccountName": {
      "type": "string",
      "metadata": {
        "description": "Name of the Storage Account used for persistent data and logs."
      },
      "value": "[variables('storageAccountName')]"
    },
    "systemIdentityPrincipalId": {
      "type": "string",
      "metadata": {
        "description": "Principal ID of the system-assigned managed identity of the App Service."
      },
      "value": "[reference(resourceId('Microsoft.Web/sites', parameters('appName')), '2024-04-01', 'full').identity.principalId]"
    }
  }
}